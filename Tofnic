<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tofnic - Professional LMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600;700&family=DM+Serif+Display&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #dbeafe;              /* নীল Background */
            --card: #ffffff;
            --primary: #2563eb;
            --primary-light: #eff6ff;
            --accent: #f59e0b;
            --text: #1e293b;
            --muted: #64748b;
            --border: #e2e8f0;
            --success: #22c55e;
            --danger: #ef4444;
            --phone-border: #1e293b;
            --shadow: 0 25px 60px -10px rgba(37,99,235,0.18);
            --app-bg: #f8fafc;
        }

        /* Dark Mode Variables */
        .dark {
            --bg: #0f172a;
            --card: #1e2937;
            --text: #f1f5f9;
            --muted: #94a3b8;
            --border: #334155;
            --app-bg: #1e2937;
            --primary-light: #1e40af;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

        body {
            font-family: 'Hind Siliguri', sans-serif;
            background: var(--bg);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
        }

        /* Ambient background blobs - নীল theme */
        body::before, body::after {
            content: '';
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            opacity: 0.35;
            pointer-events: none;
            z-index: 0;
        }
        body::before {
            width: 500px; height: 500px;
            background: radial-gradient(circle, #60a5fa, transparent);
            top: -100px; left: -100px;
        }
        body::after {
            width: 400px; height: 400px;
            background: radial-gradient(circle, #3b82f6, transparent);
            bottom: -80px; right: -80px;
        }

        /* Phone Frame */
        .phone-wrap {
            position: relative;
            z-index: 1;
        }
        .app-container {
            width: 390px;
            height: 844px;
            background: var(--app-bg);
            border-radius: 48px;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow), 0 0 0 10px var(--phone-border), 0 0 0 12px #334155;
            transition: background 0.3s ease;
        }

        /* Side buttons */
        .phone-btn {
            position: absolute;
            background: var(--phone-border);
            border-radius: 3px;
            right: -14px;
        }
        .phone-btn.power { width: 4px; height: 70px; top: 160px; }
        .phone-btn-l { position: absolute; background: var(--phone-border); border-radius: 3px; left: -14px; }
        .phone-btn-l.vol1 { width: 4px; height: 40px; top: 140px; }
        .phone-btn-l.vol2 { width: 4px; height: 40px; top: 195px; }

        /* Notch */
        .notch {
            position: absolute;
            top: 0; left: 50%;
            transform: translateX(-50%);
            width: 130px; height: 34px;
            background: var(--phone-border);
            border-bottom-left-radius: 22px;
            border-bottom-right-radius: 22px;
            z-index: 1000;
            display: flex; align-items: flex-end; justify-content: center; padding-bottom: 7px;
        }
        .notch-cam {
            width: 12px; height: 12px;
            background: #1e3a5f;
            border-radius: 50%;
            box-shadow: inset 0 0 4px #0f172a, 0 0 0 2px #1e3a5f;
        }

        /* Screens */
        .screen {
            position: absolute;
            inset: 0;
            display: none;
            flex-direction: column;
            background: var(--app-bg);
        }
        .screen.active { display: flex; animation: fadeSlide 0.28s cubic-bezier(.4,0,.2,1); }

        @keyframes fadeSlide {
            from { opacity: 0; transform: translateY(14px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        ::-webkit-scrollbar { display: none; }

        /* ── TYPOGRAPHY ── */
        .display-font { font-family: 'DM Serif Display', serif; }
        .mono { font-family: 'Space Mono', monospace; }

        /* ── CARDS ── */
        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 22px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            transition: background 0.3s ease, border-color 0.3s ease;
        }

        /* ── NAV BAR ── */
        .glass-nav {
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-top: 1px solid rgba(226,232,240,0.8);
            position: absolute; bottom: 0; width: 100%;
            z-index: 100;
            display: flex; justify-content: space-around;
            padding: 14px 20px 22px;
        }
        .dark .glass-nav { background: rgba(30,41,59,0.92); border-top-color: #334155; }

        .nav-item {
            display: flex; flex-direction: column; align-items: center; gap: 3px;
            cursor: pointer; transition: transform .15s;
        }
        .nav-item:active { transform: scale(0.88); }
        .nav-item span { font-size: 8px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }

        /* ── TOPIC BUTTON ── */
        .topic-btn {
            background: var(--card);
            border: 1.5px solid var(--border);
            border-radius: 20px;
            display: flex; align-items: center; gap: 14px;
            padding: 15px;
            cursor: pointer;
            transition: border-color .2s, transform .15s, box-shadow .2s;
            box-shadow: 0 2px 6px rgba(0,0,0,0.03);
        }
        .topic-btn:active { transform: scale(0.96); background: #f1f5f9; }
        .dark .topic-btn:active { background: #334155; }
        .topic-btn:hover { border-color: #93c5fd; box-shadow: 0 4px 16px rgba(37,99,235,0.1); }

        /* ── ICON BOX ── */
        .icon-box {
            width: 42px; height: 42px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 17px; flex-shrink: 0;
        }

        /* ── OPTION CARDS ── */
        .option-card {
            border: 2px solid var(--border);
            padding: 15px 18px;
            border-radius: 16px;
            cursor: pointer;
            transition: border-color .18s, background .18s, transform .1s;
            font-weight: 600; font-size: 14px;
            margin-bottom: 10px;
            background: white;
            color: var(--text);
        }
        .dark .option-card { background: #334155; color: #f1f5f9; }
        .option-card:hover { border-color: #93c5fd; background: #f0f7ff; }
        .dark .option-card:hover { background: #1e40af; }
        .option-card:active { transform: scale(0.98); }
        .option-card.correct { background: #dcfce7 !important; border-color: var(--success) !important; color: #166534 !important; }
        .option-card.wrong   { background: #fee2e2 !important; border-color: var(--danger) !important; color: #991b1b !important; }

        /* ── PROGRESS BAR ── */
        .prog-bar-wrap { background: #e2e8f0; height: 8px; border-radius: 99px; overflow: hidden; }
        .dark .prog-bar-wrap { background: #334155; }
        .prog-bar-fill { height: 100%; border-radius: 99px; transition: width 1.2s cubic-bezier(.4,0,.2,1); }

        /* ── BADGE ── */
        .badge {
            display: inline-block; border-radius: 8px;
            padding: 3px 10px; font-size: 9px; font-weight: 800;
            letter-spacing: .08em; text-transform: uppercase;
        }

        /* ── PULSE ANIMATION ── */
        @keyframes pulse-ring {
            0%   { box-shadow: 0 0 0 0 rgba(37,99,235,.35); }
            70%  { box-shadow: 0 0 0 12px rgba(37,99,235,0); }
            100% { box-shadow: 0 0 0 0 rgba(37,99,235,0); }
        }
        .pulse { animation: pulse-ring 2s infinite; }

        /* ── TIMER ── */
        .timer-pill {
            background: #fef2f2; color: #dc2626;
            padding: 5px 14px; border-radius: 99px;
            font-family: 'Space Mono', monospace;
            font-size: 13px; font-weight: 700; letter-spacing: .1em;
        }

        /* ── RESULT RING ── */
        .score-ring {
            width: 120px; height: 120px;
            border-radius: 50%;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            border: 6px solid #e2e8f0;
            position: relative; overflow: hidden;
        }

        /* ── BUTTONS ── */
        .btn-primary {
            width: 100%; padding: 16px;
            background: var(--primary);
            color: white; border: none;
            border-radius: 18px; font-family: 'Hind Siliguri', sans-serif;
            font-size: 16px; font-weight: 700; cursor: pointer;
            transition: background .2s, transform .15s, box-shadow .2s;
            box-shadow: 0 4px 16px rgba(37,99,235,.3);
        }
        .btn-primary:hover { background: #1d4ed8; box-shadow: 0 6px 20px rgba(37,99,235,.4); }
        .btn-primary:active { transform: scale(0.98); }

        .btn-ghost {
            width: 100%; padding: 14px;
            background: transparent; border: none;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 14px; font-weight: 700;
            color: var(--muted); cursor: pointer;
            transition: color .2s;
        }
        .btn-ghost:hover { color: var(--text); }

        /* ── INPUT ── */
        .field {
            width: 100%; padding: 15px 18px;
            border: 2px solid var(--border);
            border-radius: 16px;
            font-family: 'Hind Siliguri', sans-serif;
            font-size: 15px; color: var(--text);
            background: white; outline: none;
            transition: border-color .2s, box-shadow .2s;
        }
        .dark .field { background: #334155; color: #f1f5f9; }
        .field:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(37,99,235,.1); }
        .field::placeholder { color: var(--muted); }

        /* ── WELCOME GRADIENT ── */
        .welcome-hero {
            background: linear-gradient(145deg, #1e3a8a 0%, #2563eb 50%, #3b82f6 100%);
            position: relative; overflow: hidden;
        }

        /* ── MNC TIPS BANNER ── */
        .tips-banner {
            background: white;
            border-radius: 22px;
            padding: 14px 18px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            margin-bottom: 20px;
        }
        .dark .tips-banner { background: #1e2937; }

        /* ── QUIZ HEADER ── */
        .quiz-header-bar {
            background: white;
            border-bottom: 1px solid var(--border);
            padding: 48px 20px 14px;
            display: flex; justify-content: space-between; align-items: center;
        }
        .dark .quiz-header-bar { background: #1e2937; }

        /* ── EXPLANATION BOX ── */
        .exp-box {
            background: linear-gradient(135deg, #eff6ff, #f0fdf4);
            border: 1.5px solid #bfdbfe;
            border-radius: 20px; padding: 20px;
            margin-top: 16px; margin-bottom: 80px;
        }
        .dark .exp-box { background: linear-gradient(135deg, #1e40af, #164e63); border-color: #3b82f6; }

        /* ── CLOSE BTN ── */
        .close-btn {
            width: 36px; height: 36px;
            background: #f1f5f9; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--muted);
            transition: background .2s;
        }
        .dark .close-btn { background: #334155; }
        .close-btn:hover { background: #e2e8f0; }

        /* ── AVATAR RING ── */
        .avatar-ring {
            padding: 3px; border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        }
    </style>
</head>
<body>

<div class="phone-wrap">
